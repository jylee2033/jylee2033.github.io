---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/life', label: 'Life' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__logo">Julia Lee</a>
    <ul class="navbar__links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['navbar__link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="/resume.pdf" class="navbar__resume" aria-label="Resume">
      Resume ↓
    </a>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 247, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .navbar__logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .navbar__links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .navbar__link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .navbar__link:hover,
  .navbar__link.active {
    color: var(--color-primary);
    font-weight: 600;
  }
  .navbar__resume {
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.2s;
  }
  .navbar__resume:hover { background: var(--color-primary-dark); }
  .navbar__resume--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .navbar__links { gap: 1rem; }
    .navbar__resume { display: none; }
  }
</style>
