---
interface Props {
  name: string;
  tagline: string;
  subline: string;
  photoSrc: string;
  photoAlt: string;
}
const { name, tagline, subline, photoSrc, photoAlt } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__photo-wrap">
      <img src={photoSrc} alt={photoAlt} class="hero__photo" />
    </div>
    <div class="hero__text">
      <p class="label">Hi there 👋</p>
      <h1>{name}</h1>
      <p class="hero__tagline">{tagline}</p>
      <p class="hero__subline">{subline}</p>
      <div class="hero__actions">
        <a href="/projects" class="btn btn--primary">View Projects →</a>
        <a href="/about" class="btn btn--ghost">About Me</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-hero-bg) 0%, #fff5f6 50%, #eef1f8 100%);
    padding: 5rem 0;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 3rem;
  }
  .hero__photo-wrap {
    width: 220px;
    height: 280px;
    flex-shrink: 0;
  }
  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    -webkit-mask-image: linear-gradient(
      to bottom, transparent 0%, black 8%, black 92%, transparent 100%
    );
    mask-image: linear-gradient(
      to bottom, transparent 0%, black 8%, black 92%, transparent 100%
    );
  }
  .hero__text { display: flex; flex-direction: column; gap: 0.75rem; }
  .hero__tagline {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  .hero__subline { color: var(--color-text-muted); }
  .hero__actions { display: flex; gap: 1rem; margin-top: 0.5rem; flex-wrap: wrap; }

  .btn {
    display: inline-block;
    border-radius: var(--radius-full);
    padding: 0.6rem 1.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .btn--primary { background: var(--color-primary); color: white; }
  .btn--primary:hover { background: var(--color-primary-dark); }
  .btn--ghost {
    border: 1.5px solid var(--color-steel);
    color: var(--color-text-muted);
  }
  .btn--ghost:hover { border-color: var(--color-primary); color: var(--color-primary); }

  @media (max-width: 640px) {
    .hero__inner { grid-template-columns: 1fr; text-align: center; }
    .hero__photo-wrap { width: 150px; height: 190px; margin: 0 auto; }
    .hero__actions { justify-content: center; }
  }
</style>
