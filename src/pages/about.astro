---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillChips from '../components/SkillChips.astro';
import Timeline from '../components/Timeline.astro';

const skillGroups = [
  {
    label: 'Programming',
    color: 'purple' as const,
    skills: ['Python', 'C/C++', 'Java', 'SQL/MySQL'],
  },
  {
    label: 'QA & Testing',
    color: 'pink' as const,
    skills: ['Test Automation', 'Manual Testing', 'Regression Testing', 'Integration Testing', 'Test Case Design', 'SDLC', 'Scrum'],
  },
  {
    label: 'Tools & Systems',
    color: 'steel' as const,
    skills: ['Git', 'Jenkins', 'Docker', 'Jira', 'qTest', 'Linux', 'Windows'],
  },
];

const timelineItems = [
  {
    period: 'Jan 2024 – Aug 2024',
    title: 'Automation Tester Intern',
    org: 'Safe Fleet',
    description: 'Implemented Pytest frameworks and designed standardized test templates to streamline QA processes.',
    type: 'internship' as const,
    href: '/projects/automation-tester',
    year: '2024',
  },
  {
    period: 'Jan 2025 – Aug 2025',
    title: 'Software Test Engineer Intern',
    org: 'Semtech',
    description: 'Validated cellular modem products (EM92, EM86). Managed test environments on Windows and Linux, executed driver and firmware tests.',
    type: 'internship' as const,
    href: '/projects/software-test-engineer',
    year: '2025',
  },
];
---

<BaseLayout title="About" description="About Jooyoung (Julia) Lee — Computing Science student at SFU, QA Engineer, based in Vancouver.">
  <section class="section">
    <div class="container about">

      <div class="about__intro">
        <div class="about__photo-wrap">
          <img src="/images/avatar.png" alt="Jooyoung (Julia) Lee" class="about__photo" />
        </div>
        <div class="about__intro-text">
          <h2>About Me</h2>
          <p>
            Hi, I'm Jooyoung (Julia) Lee, a Computing Science graduate from Simon Fraser University (Dec 2025), originally from Korea and now based in Vancouver. Through my internships, I discovered that QA and testing suit me well — I enjoy finding bugs, thinking through edge cases, and building automation that makes testing more reliable.
          </p>
        </div>
      </div>

      <div class="about__section fade-in">
        <h2 style="margin-bottom: 1.5rem;">Skills</h2>
        <SkillChips groups={skillGroups} />
      </div>

      <div class="about__section fade-in">
        <h2 style="margin-bottom: 1.5rem;">Experience</h2>
        <Timeline
          items={timelineItems}
          eduName="SFU — Computing Science (B.Sc.)"
          eduStart="Sep 2020"
          eduEnd="Dec 2025"
          seeking={{ year: '2026', text: 'Open to opportunities' }}
        />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .about__intro {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3.5rem;
  }
  .about__intro-text h2 { margin-bottom: 0.75rem; }
  .about__intro-text p { color: var(--color-text-muted); line-height: 1.7; }

  .about__photo-wrap {
    width: 180px;
    height: 220px;
    flex-shrink: 0;
    -webkit-mask-image: linear-gradient(
      to right, transparent 0%, black 20%, black 80%, transparent 100%
    );
    mask-image: linear-gradient(
      to right, transparent 0%, black 20%, black 80%, transparent 100%
    );
  }
  .about__photo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    -webkit-mask-image: linear-gradient(
      to bottom, transparent 0%, black 8%, black 92%, transparent 100%
    );
    mask-image: linear-gradient(
      to bottom, transparent 0%, black 8%, black 92%, transparent 100%
    );
  }
  .about__section { margin-bottom: 3.5rem; }

  @media (max-width: 600px) {
    .about__intro { grid-template-columns: 1fr; }
    .about__photo-wrap { width: 130px; height: 160px; margin: 0 auto; }
  }
</style>
