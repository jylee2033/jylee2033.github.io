---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Julia Lee.">
  <section class="section">
    <div class="container contact">
      <h2>Get in Touch</h2>
      <p class="contact__sub">
        I'm currently open to full-time opportunities. Feel free to reach out!
      </p>

      <div class="contact__links">
        <a href="mailto:jylee2033@gmail.com" class="contact__link">
          <span class="contact__link-icon">✉️</span>
          jylee2033@gmail.com
        </a>
        <a href="https://github.com/jylee2033" target="_blank" rel="noopener" class="contact__link">
          <span class="contact__link-icon">🐙</span>
          github.com/jylee2033
        </a>
      </div>

      <form
        action="https://formspree.io/f/YOUR_FORMSPREE_ID"
        method="POST"
        class="contact__form"
      >
        <label class="form-field">
          <span>Name</span>
          <input type="text" name="name" required placeholder="Your name" />
        </label>
        <label class="form-field">
          <span>Email</span>
          <input type="email" name="email" required placeholder="your@email.com" />
        </label>
        <label class="form-field">
          <span>Message</span>
          <textarea name="message" required rows="5" placeholder="What's on your mind?"></textarea>
        </label>
        <button type="submit" class="btn btn--primary">Send Message →</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact { max-width: 600px; }
  .contact__sub { color: var(--color-text-muted); margin: 0.5rem 0 2rem; }

  .contact__links { display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2.5rem; }
  .contact__link {
    display: flex; align-items: center; gap: 0.6rem;
    font-size: 0.95rem; color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .contact__link:hover { color: var(--color-primary); }

  .contact__form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-field span { font-size: 0.85rem; font-weight: 600; color: var(--color-primary-dark); }
  .form-field input,
  .form-field textarea {
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.6rem 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.2s;
    resize: vertical;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  .btn { display: inline-block; border-radius: var(--radius-full); padding: 0.6rem 1.4rem; font-size: 0.9rem; font-weight: 600; transition: all 0.2s; border: none; cursor: pointer; }
  .btn--primary { background: var(--color-primary); color: white; }
  .btn--primary:hover { background: var(--color-primary-dark); }
</style>
