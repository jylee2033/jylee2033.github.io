---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Projects" description="Jooyoung (Julia) Lee's projects — embedded systems, data science, QA automation, and more.">
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom: 0.5rem;">Projects</h2>
      <p class="page-sub">
        A collection of academic projects and work experiences.
      </p>
      <ProjectGrid projects={sorted} />
    </div>
  </section>
</BaseLayout>
