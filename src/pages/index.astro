---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSplit from '../components/HeroSplit.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';
import { pianoVideos, bakingPhotos, photographyPhotos } from '../data/life';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const lifePreviewPhotos = [
  ...bakingPhotos.slice(-2),
  ...photographyPhotos.slice(-2),
];
const lifePreviewVideos = pianoVideos.slice(0, 2);
---

<BaseLayout title="Home" description="Julia Lee — Computing Science student at SFU, QA Engineer, based in Vancouver.">
  <HeroSplit
    name="Julia Lee"
    tagline="Computing Science @ SFU · QA Engineer"
    subline="Based in Vancouver, Canada. Passionate about testing, clean code, and learning step by step."
    photoSrc="/images/avatar.png"
    photoAlt="Julia Lee"
  />

  <section class="section fade-in">
    <div class="container">
      <p class="label" style="margin-bottom: 1.5rem;">Featured Projects</p>
      <ProjectGrid projects={featuredProjects} />
    </div>
  </section>

  <section class="section fade-in">
    <div class="container">
      <p class="label" style="margin-bottom: 1rem;">Life — Outside of Work</p>
      {(lifePreviewPhotos.length > 0 || lifePreviewVideos.length > 0) && (
        <div class="life-preview-grid">
          {lifePreviewVideos.map(v => (
            <a href="/life" class="life-preview-thumb">
              <img
                src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`}
                alt={v.title}
                class="life-preview-img"
              />
            </a>
          ))}
          {lifePreviewPhotos.map(photo => (
            <img src={photo.src} alt={photo.alt} class="life-preview-img" />
          ))}
        </div>
      )}
      <a href="/life" class="life-preview-link">Life 더 보기 →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .life-preview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .life-preview-thumb {
    display: block;
  }
  .life-preview-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
  .life-preview-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  .life-preview-link:hover { color: var(--color-primary-dark); }

  @media (max-width: 600px) {
    .life-preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
